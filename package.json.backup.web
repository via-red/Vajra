{
  "name": "vajra-material-ide",
  "version": "0.1.0",
  "description": "Material Science Intelligent IDE based on PMD standards",
  "main": "src/main.js",
  "scripts": {
    "start": "electron .",
    "dev": "npm run build:dev && electron dist --dev",
    "build": "npm run build:prod",
    "build:dev": "node scripts/build.js",
    "build:prod": "node scripts/build.js && electron-builder",
    "test": "jest",
    "lint": "eslint src/**/*.ts",
    "format": "prettier --write src/**/*.ts",
    "clean": "node scripts/clean.js",
    "postinstall": "npm run build:dev"
  },
  "keywords": [
    "material-science",
    "ide",
    "pmd",
    "ontology",
    "semantic-web",
    "materials-informatics"
  ],
  "author": "Your Name",
  "license": "Apache-2.0",
  "devDependencies": {
    "@types/node": "^20.0.0",
    "@types/react": "^18.2.0",
    "@types/react-dom": "^18.2.0",
    "@typescript-eslint/eslint-plugin": "^6.0.0",
    "@typescript-eslint/parser": "^6.0.0",
    "chokidar": "^3.5.3",
    "electron": "^29.0.0",
    "electron-builder": "^24.0.0",
    "eslint": "^8.45.0",
    "jest": "^29.0.0",
    "prettier": "^3.0.0",
    "typescript": "^5.3.0"
  },
  "dependencies": {
    "monaco-editor": "^0.45.0",
    "react": "^18.2.0",
    "react-dom": "^18.2.0",
    "n3": "^1.16.0",
    "rdflib": "^2.2.0",
    "sparqljs": "^3.6.0"
  },
  "repository": {
    "type": "git",
    "url": "https://github.com/yourusername/vajra.git"
  },
  "bugs": {
    "url": "https://github.com/yourusername/vajra/issues"
  },
  "homepage": "https://github.com/yourusername/vajra#readme",
  "build": {
    "appId": "com.vajra.materialide",
    "productName": "Vajra Material IDE",
    "directories": {
      "output": "dist"
    },
    "files": [
      "src/**/*",
      "resources/**/*",
      "ontologies/**/*",
      "package.json"
    ],
    "extraResources": [
      "ontologies/**"
    ]
  }
}