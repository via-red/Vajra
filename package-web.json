{
  "name": "vajra-material-ide-web",
  "version": "0.1.0",
  "description": "Vajra Material IDE - Web Version (No Electron)",
  "private": true,
  "scripts": {
    "build:ts": "tsc",
    "build:web": "node scripts/build-web.js",
    "build": "npm run build:ts && npm run build:web",
    "start": "npx http-server dist-web -p 3000 -o",
    "dev": "node scripts/dev-web.js",
    "clean": "node scripts/clean-web.js"
  },
  "dependencies": {
    "monaco-editor": "^0.45.0",
    "n3": "^1.16.0",
    "react": "^18.2.0",
    "react-dom": "^18.2.0"
  },
  "devDependencies": {
    "@types/node": "^20.0.0",
    "@types/react": "^18.2.0",
    "@types/react-dom": "^18.2.0",
    "typescript": "^5.3.0"
  }
}